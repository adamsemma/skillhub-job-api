# Copy this file to .env and adjust as needed.
# Vite only exposes variables prefixed with VITE_ to client-side code.

# Base URL of the backend API (no trailing slash, no /api/v1 suffix -
# the frontend calls root-level compat routes like /api/search, /api/auth/login).
VITE_API_URL=http://localhost:8001

# Set to "false" to disable the offline mock-data fallback and surface
# real network/API errors instead (recommended for staging/production).
VITE_USE_MOCK=true
