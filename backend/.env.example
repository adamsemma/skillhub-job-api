# Copy this file to .env and fill in real values.
# NEVER commit .env - it is already listed in .gitignore.

# API Settings
APP_NAME=SkillHub Job API
APP_VERSION=1.0.0
# Use False (or "production"/"release") for any deployed environment.
DEBUG=False
API_PREFIX=/api/v1

# Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# The app will refuse to start with DEBUG=False if this is left at a placeholder value.
SECRET_KEY=replace_with_a_securely_generated_random_value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql://postgres:your_password@127.0.0.1:5432/skillhub
# Per-process pool. Total Postgres connections = num_app_processes * (DB_POOL_SIZE + DB_MAX_OVERFLOW).
# For real concurrency, scale out with more app replicas + a pooler (PgBouncer) in
# front of Postgres rather than growing these indefinitely.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800

REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=50

# CORS - JSON array of allowed origins
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "https://skillhub.meritlives.com"]

# AI Services (optional - leave blank to disable AI-assisted matching)
OPENAI_API_KEY=
USE_LOCAL_LLM=False
LOCAL_LLM_URL=http://localhost:11434/api/generate

# Job Search (JobSpy)
JOBSPY_SITES=["linkedin", "indeed", "glassdoor"]
JOBSPY_COUNTRY_INDEED=usa
SEARCH_TIMEOUT=30
MAX_SEARCH_RESULTS=50
# Cache search results in Redis for this many seconds -- avoids re-scraping
# job boards on every repeated/popular query.
SEARCH_CACHE_TTL_SECONDS=300
# Caps concurrent JobSpy scrapes per process, so a burst of search requests
# can't exhaust the thread pool or get the server rate-limited by job boards.
MAX_CONCURRENT_SCRAPES=8

# Social Media (optional)
TWITTER_API_KEY=
TWITTER_API_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
